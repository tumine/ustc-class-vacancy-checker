<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext for USTC domains that may use HTTP redirects during CAS login -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">ustc.edu.cn</domain>
    </domain-config>
</network-security-config>
